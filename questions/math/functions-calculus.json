  "questions": [
    {
      "id": "q1",
      "year": 105,
      "text": "設二次函數 f(x) = ax² + bx + c 的圖形開口向下，且頂點在第一象限。下列何者正確？",
      "options": [
        "(A) a > 0，b > 0",
        "(B) a < 0，b > 0",
        "(C) a > 0，c < 0",
        "(D) a < 0，c < 0"
      ],
      "answer": "B",
      "explanation": "解析：開口向下表示 a < 0。頂點的 x 座標 = -b/(2a) > 0，因 a < 0，故 -b/(2a) > 0 需要 b > 0。因此 a < 0 且 b > 0，選(B)。",
      "tags": ["多項式函數"]
    },
    {
      "id": "q2",
      "year": 106,
      "text": "若 log₂3 = a，log₂5 = b，則 log₄15 之值為何？",
      "options": [
        "(A) (a + b)/2",
        "(B) a + b",
        "(C) ab/2",
        "(D) 2(a + b)"
      ],
      "answer": "A",
      "explanation": "解析：log₄15 = log₂15 / log₂4 = (log₂3 + log₂5) / 2 = (a + b)/2。利用換底公式 log₄15 = log₂15 / log₂4，其中 log₂4 = 2，故選(A)。",
      "tags": ["指數與對數函數"]
    },
    {
      "id": "q3",
      "year": 107,
      "text": "在 0° ≤ θ ≤ 360° 的範圍內，方程式 2sin²θ - sinθ - 1 = 0 有幾個解？",
      "options": [
        "(A) 1 個",
        "(B) 2 個",
        "(C) 3 個",
        "(D) 4 個"
      ],
      "answer": "C",
      "explanation": "解析：令 t = sinθ，得 2t² - t - 1 = 0，(2t + 1)(t - 1) = 0，t = -1/2 或 t = 1。sinθ = 1 時 θ = 90°（1 個解）；sinθ = -1/2 時 θ = 210° 或 330°（2 個解）。共 3 個解，選(C)。",
      "tags": ["三角函數"]
    },
    {
      "id": "q4",
      "year": 108,
      "text": "設 f(x) = x³ - 3x² + 2，求 f'(1) 之值為何？",
      "options": [
        "(A) -3",
        "(B) -1",
        "(C) 0",
        "(D) 3"
      ],
      "answer": "A",
      "explanation": "解析：f'(x) = 3x² - 6x，f'(1) = 3(1)² - 6(1) = 3 - 6 = -3，故選(A)。",
      "tags": ["極限與微積分初步"]
    },
    {
      "id": "q5",
      "year": 109,
      "text": "已知 f(x) = 2x³ - 5x + 1，以 (x - 2) 除 f(x) 所得的餘式為何？",
      "options": [
        "(A) 3",
        "(B) 5",
        "(C) 7",
        "(D) 9"
      ],
      "answer": "C",
      "explanation": "解析：根據餘式定理，f(x) 除以 (x - 2) 的餘式 = f(2) = 2(8) - 5(2) + 1 = 16 - 10 + 1 = 7，故選(C)。",
      "tags": ["多項式函數"]
    },
    {
      "id": "q6",
      "year": 111,
      "text": "函數 y = 3ˣ⁻¹ + 2 的圖形必通過下列哪一個點？",
      "options": [
        "(A) (0, 3)",
        "(B) (1, 3)",
        "(C) (1, 2)",
        "(D) (0, 2)"
      ],
      "answer": "B",
      "explanation": "解析：當 x = 1 時，y = 3¹⁻¹ + 2 = 3⁰ + 2 = 1 + 2 = 3，故圖形通過 (1, 3)，選(B)。",
      "tags": ["指數與對數函數"]
    },
    {
      "id": "q7",
      "year": 112,
      "text": "設 f(x) = x² - 4x + 3，求 ∫₁³ f(x) dx 之值為何？",
      "options": [
        "(A) -4/3",
        "(B) 0",
        "(C) 4/3",
        "(D) 8/3"
      ],
      "answer": "A",
      "explanation": "解析：∫₁³ (x² - 4x + 3) dx = [x³/3 - 2x² + 3x]₁³ = (9 - 18 + 9) - (1/3 - 2 + 3) = 0 - 4/3 = -4/3，故選(A)。",
      "tags": ["極限與微積分初步"]
    },
    {
      "id": "q8",
      "year": 113,
      "text": "已知 sin α = 3/5 且 α 在第二象限，cos α 的值為何？",
      "options": [
        "(A) 4/5",
        "(B) -4/5",
        "(C) 3/5",
        "(D) -3/5"
      ],
      "answer": "B",
      "explanation": "解析：由 sin²α + cos²α = 1，cos²α = 1 - 9/25 = 16/25，cosα = ±4/5。因 α 在第二象限，cosα < 0，故 cosα = -4/5，選(B)。",
      "tags": ["三角函數"]
    }
  ]
