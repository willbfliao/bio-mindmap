  "questions": [
    {
      "id": "q1",
      "year": 105,
      "text": "直線 L: 2x - 3y + 6 = 0 的 x 截距與 y 截距分別為何？",
      "options": [
        "(A) x 截距 -3，y 截距 2",
        "(B) x 截距 3，y 截距 -2",
        "(C) x 截距 -3，y 截距 -2",
        "(D) x 截距 3，y 截距 2"
      ],
      "answer": "A",
      "explanation": "解析：x 截距令 y = 0，得 2x + 6 = 0，x = -3。y 截距令 x = 0，得 -3y + 6 = 0，y = 2。故 x 截距為 -3，y 截距為 2，選(A)。",
      "tags": ["直線與圓"]
    },
    {
      "id": "q2",
      "year": 106,
      "text": "設 →a = (2, -1)，→b = (3, 4)，則 →a · →b 之值為何？",
      "options": [
        "(A) 2",
        "(B) 5",
        "(C) 10",
        "(D) 11"
      ],
      "answer": "A",
      "explanation": "解析：→a · →b = 2×3 + (-1)×4 = 6 - 4 = 2，故選(A)。",
      "tags": ["平面向量"]
    },
    {
      "id": "q3",
      "year": 107,
      "text": "點 P(3, -1) 到直線 4x - 3y - 2 = 0 的距離為何？",
      "options": [
        "(A) 1",
        "(B) 13/5",
        "(C) 3",
        "(D) 17/5"
      ],
      "answer": "B",
      "explanation": "解析：點到直線距離公式 d = |ax₀ + by₀ + c| / √(a² + b²) = |4(3) - 3(-1) - 2| / √(16 + 9) = |12 + 3 - 2| / 5 = 13/5，故選(B)。",
      "tags": ["直線與圓"]
    },
    {
      "id": "q4",
      "year": 108,
      "text": "圓 x² + y² - 4x + 6y - 3 = 0 的圓心與半徑為何？",
      "options": [
        "(A) 圓心 (2, -3)，半徑 4",
        "(B) 圓心 (-2, 3)，半徑 4",
        "(C) 圓心 (2, -3)，半徑 16",
        "(D) 圓心 (-2, 3)，半徑 16"
      ],
      "answer": "A",
      "explanation": "解析：配方得 (x-2)² + (y+3)² = 4 + 9 + 3 = 16 = 4²。圓心 (2, -3)，半徑 4，故選(A)。",
      "tags": ["直線與圓"]
    },
    {
      "id": "q5",
      "year": 109,
      "text": "設橢圓方程式為 x²/25 + y²/9 = 1，則此橢圓的焦點座標為何？",
      "options": [
        "(A) (±3, 0)",
        "(B) (±4, 0)",
        "(C) (0, ±3)",
        "(D) (0, ±4)"
      ],
      "answer": "B",
      "explanation": "解析：a² = 25，b² = 9，c² = a² - b² = 25 - 9 = 16，c = 4。因 a² 在 x² 項下，焦點在 x 軸上，為 (±4, 0)，故選(B)。",
      "tags": ["圓錐曲線"]
    },
    {
      "id": "q6",
      "year": 111,
      "text": "空間中兩點 A(1, 2, 3) 與 B(4, -2, 5) 的距離為何？",
      "options": [
        "(A) √17",
        "(B) √29",
        "(C) √33",
        "(D) 7"
      ],
      "answer": "B",
      "explanation": "解析：d = √((4-1)² + (-2-2)² + (5-3)²) = √(9 + 16 + 4) = √29，故選(B)。",
      "tags": ["空間向量與空間幾何"]
    },
    {
      "id": "q7",
      "year": 112,
      "text": "兩向量 →a = (1, 2) 與 →b = (k, -3) 互相垂直，則 k 之值為何？",
      "options": [
        "(A) -6",
        "(B) 3/2",
        "(C) 6",
        "(D) -3/2"
      ],
      "answer": "C",
      "explanation": "解析：兩向量垂直則內積為零：→a · →b = 1×k + 2×(-3) = k - 6 = 0，k = 6，故選(C)。",
      "tags": ["平面向量"]
    },
    {
      "id": "q8",
      "year": 113,
      "text": "拋物線 y² = 12x 的焦點座標與準線方程式為何？",
      "options": [
        "(A) 焦點 (3, 0)，準線 x = -3",
        "(B) 焦點 (12, 0)，準線 x = -12",
        "(C) 焦點 (0, 3)，準線 y = -3",
        "(D) 焦點 (6, 0)，準線 x = -6"
      ],
      "answer": "A",
      "explanation": "解析：y² = 12x，對照標準式 y² = 4px，4p = 12，p = 3。焦點 (p, 0) = (3, 0)，準線 x = -p = -3，故選(A)。",
      "tags": ["圓錐曲線"]
    }
