{
  "topicId": "aqueous-equilibrium",
  "year_stats": "105-114年出題約20題",
  "questions": [
    {
      "id": "q1",
      "year": 113,
      "text": "25°C 時，某溶液的 [OH⁻] = 1.0×10⁻³ M，其 pH 值為何？",
      "options": [
        "(A) 3",
        "(B) 7",
        "(C) 11",
        "(D) 14"
      ],
      "answer": "C",
      "explanation": "解析：pOH=-log(10⁻³)=3，pH=14-pOH=14-3=11。此為鹼性溶液。",
      "tags": ["水的自解離"]
    },
    {
      "id": "q2",
      "year": 111,
      "text": "醋酸的 Ka = 1.8×10⁻⁵，其共軛鹼 CH₃COO⁻ 的 Kb 約為？",
      "options": [
        "(A) 1.8×10⁻⁵",
        "(B) 5.6×10⁻¹⁰",
        "(C) 1.0×10⁻⁷",
        "(D) 1.0×10⁻¹⁴"
      ],
      "answer": "B",
      "explanation": "解析：Ka×Kb=Kw，Kb=Kw/Ka=1.0×10⁻¹⁴/1.8×10⁻⁵=5.6×10⁻¹⁰。",
      "tags": ["弱酸弱鹼的游離平衡"]
    },
    {
      "id": "q3",
      "year": 110,
      "text": "在醋酸溶液中加入醋酸鈉，下列何者會發生？",
      "options": [
        "(A) [H⁺] 增大",
        "(B) 醋酸的游離度增大",
        "(C) [H⁺] 降低",
        "(D) pH 降低"
      ],
      "answer": "C",
      "explanation": "解析：加入CH₃COONa提供大量CH₃COO⁻（同離子效應），使醋酸游離平衡左移，[H⁺]降低，pH升高。",
      "tags": ["同離子效應"]
    },
    {
      "id": "q4",
      "year": 112,
      "text": "某緩衝溶液含有等濃度的 CH₃COOH 和 CH₃COONa，已知醋酸的 pKa = 4.74，此緩衝溶液的 pH 約為？",
      "options": [
        "(A) 2.37",
        "(B) 4.74",
        "(C) 7.00",
        "(D) 9.26"
      ],
      "answer": "B",
      "explanation": "解析：由Henderson-Hasselbalch方程式，pH=pKa+log([A⁻]/[HA])。[A⁻]=[HA]時log1=0，所以pH=pKa=4.74。",
      "tags": ["緩衝溶液"]
    },
    {
      "id": "q5",
      "year": 109,
      "text": "用 NaOH 滴定 CH₃COOH（弱酸），當量點的 pH 為何？",
      "options": [
        "(A) pH < 7",
        "(B) pH = 7",
        "(C) pH > 7",
        "(D) 視指示劑而定"
      ],
      "answer": "C",
      "explanation": "解析：強鹼滴定弱酸，當量點時溶液中只有共軛鹼CH₃COO⁻（水解呈鹼性），所以pH>7。",
      "tags": ["酸鹼滴定曲線"]
    },
    {
      "id": "q6",
      "year": 108,
      "text": "AgCl 的 Ksp = 1.8×10⁻¹⁰，在純水中 Ag⁺ 的飽和濃度約為？",
      "options": [
        "(A) 1.3×10⁻⁵ M",
        "(B) 1.8×10⁻¹⁰ M",
        "(C) 9.0×10⁻⁶ M",
        "(D) 1.8×10⁻⁵ M"
      ],
      "answer": "A",
      "explanation": "解析：AgCl→Ag⁺+Cl⁻，設溶解度為s，Ksp=s²=1.8×10⁻¹⁰，s=√(1.8×10⁻¹⁰)≈1.3×10⁻⁵ M。",
      "tags": ["沉澱與溶解度積常數"]
    },
    {
      "id": "q7",
      "year": 107,
      "text": "在 AgCl 飽和溶液中加入 NaCl，會發生什麼？",
      "options": [
        "(A) AgCl 溶解度增大",
        "(B) 產生更多 AgCl 沉澱",
        "(C) Ksp 值改變",
        "(D) 無任何變化"
      ],
      "answer": "B",
      "explanation": "解析：加入NaCl使[Cl⁻]增大，Qsp>Ksp，產生更多AgCl沉澱。Ksp只與溫度有關，不會因加入NaCl而改變。",
      "tags": ["沉澱與溶解度積常數"]
    },
    {
      "id": "q8",
      "year": 106,
      "text": "弱酸的游離度會隨稀釋而如何變化？",
      "options": [
        "(A) 游離度增大",
        "(B) 游離度減小",
        "(C) 游離度不變",
        "(D) 視弱酸種類而定"
      ],
      "answer": "A",
      "explanation": "解析：稀釋弱酸溶液時，根據勒沙特列原理平衡向右移（游離方向），游離度增大。但注意[H⁺]不一定增大。",
      "tags": ["弱酸弱鹼的游離平衡"]
    }
  ]
}
